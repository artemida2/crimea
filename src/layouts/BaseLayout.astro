---
import "../styles/global.css";
import { url } from "../utils/url";

interface Props {
  title: string;
  description: string;
  canonical?: string;
  ogImage?: string;
  jsonLd?: Record<string, unknown> | Record<string, unknown>[];
}

const { title, description, canonical, ogImage, jsonLd } = Astro.props;
const siteName = "Крым · издание о полуострове";
const fullTitle = title.includes("Крым") ? title : `${title} — ${siteName}`;
const canonicalUrl = canonical ?? new URL(Astro.url.pathname, Astro.site).toString();
const og = ogImage ?? new URL(url("img/hero-coast-1600.webp").replace(/^\//, ""), Astro.site).toString();
const year = new Date().getFullYear();
---

<!doctype html>
<html lang="ru">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <meta name="theme-color" content="#0E1B3A" />
    <link rel="icon" type="image/svg+xml" href={url("favicon.svg")} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,500;0,600;1,400;1,500;1,600&family=Inter:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />

    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />

    <meta property="og:type" content="website" />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={og} />
    <meta property="og:locale" content="ru_RU" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />

    {jsonLd && (
      <script
        type="application/ld+json"
        set:html={JSON.stringify(jsonLd)}
      />
    )}
  </head>
  <body>
    <header class="site-header">
      <div class="container">
        <a href={url()} class="logo">
          Крым
          <span class="small">издание о полуострове</span>
        </a>
        <nav class="main-nav">
          <a href={url("marshrut/")}>Маршруты</a>
          <a href={url("mesta/")}>Места</a>
          <a href={url("#planner")}>AI-планировщик</a>
        </nav>
      </div>
    </header>

    <main>
      <slot />
    </main>

    <footer class="site-footer">
      <div class="container">
        <div>
          <p class="brand">Крым</p>
          <p style="max-width: 32ch;">
            Независимое онлайн-издание о маршрутах, местах и людях полуострова.
            AI помогает собрать ваш собственный план — мы лишь редакция.
          </p>
        </div>
        <div>
          <h4>Разделы</h4>
          <ul>
            <li><a href={url("marshrut/")}>Маршруты</a></li>
            <li><a href={url("mesta/")}>Места</a></li>
            <li><a href={url("#planner")}>AI-планировщик</a></li>
          </ul>
        </div>
        <div>
          <h4>Авторам и читателям</h4>
          <ul>
            <li><a href={url("atribucia/")}>Авторы фотографий</a></li>
            <li><a href="mailto:hello@crimea.example">Связаться</a></li>
          </ul>
        </div>
      </div>
      <div class="container">
        <p class="meta">
          © {year} Крым · издание о полуострове · MVP-версия. Информация носит справочный характер. Цены, расписание и условия посещения проверяйте на официальных сайтах перед поездкой.
        </p>
      </div>
    </footer>
  </body>
</html>
