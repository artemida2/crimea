---
import Picture from "./Picture.astro";

interface Props {
  href: string;
  title: string;
  description: string;
  city: string;
  category?: string;
  image?: string;
  sizes?: string;
}

const {
  href,
  title,
  description,
  city,
  category,
  image,
  sizes = "(min-width: 900px) 33vw, 100vw",
} = Astro.props;
---

<a href={href} class="editorial-card">
  {image && (
    <Picture
      slug={image}
      alt={title}
      sizes={sizes}
      aspect="4/5"
    />
  )}
  <div class="meta-line">
    {city}{category ? ` · ${category}` : ""}
  </div>
  <h3>{title}</h3>
  <p class="descr">{description}</p>
</a>
