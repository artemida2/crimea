---
interface Props {
  href: string;
  title: string;
  description: string;
  days: number;
  city: string;
  tags?: string[];
}

const { href, title, description, days, city, tags = [] } = Astro.props;
---

<a href={href} class="card" style="display:block; color: var(--color-text); text-decoration:none;">
  <div style="font-size:0.85rem; color: var(--color-text-muted); margin-bottom:0.4rem">
    {city} · {days} {days === 1 ? "день" : days < 5 ? "дня" : "дней"}
  </div>
  <h3 style="margin: 0 0 0.4rem 0; font-family: var(--font-sans); font-size:1.15rem; color: var(--color-text);">{title}</h3>
  <p class="muted" style="margin-bottom:0.6rem">{description}</p>
  {tags.length > 0 && (
    <div>
      {tags.map((t) => <span class="tag">{t}</span>)}
    </div>
  )}
</a>
