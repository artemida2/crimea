---
import Picture from "./Picture.astro";

interface Props {
  href: string;
  title: string;
  description: string;
  days: number;
  city: string;
  tags?: string[];
  image?: string;
  /** sizes attr for the inline picture */
  sizes?: string;
}

const {
  href,
  title,
  description,
  days,
  city,
  tags = [],
  image,
  sizes = "(min-width: 900px) 33vw, 100vw",
} = Astro.props;

const dayWord = days === 1 ? "день" : days < 5 ? "дня" : "дней";
---

<a href={href} class="editorial-card">
  {image && (
    <Picture
      slug={image}
      alt={title}
      sizes={sizes}
      aspect="16/10"
    />
  )}
  <div class="meta-line">
    {city} · {days} {dayWord}
  </div>
  <h3>{title}</h3>
  <p class="descr">{description}</p>
  {tags.length > 0 && (
    <div class="tags">
      {tags.map((t) => <span class="tag">{t}</span>)}
    </div>
  )}
</a>
