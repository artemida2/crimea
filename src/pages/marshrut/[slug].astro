---
import BaseLayout from "../../layouts/BaseLayout.astro";
import PlannerForm from "../../components/PlannerForm.astro";
import routes from "../../data/routes.json";
import { getRouteContent } from "../../content/routes-content";
import { url } from "../../utils/url";

export function getStaticPaths() {
  return routes.map((route) => ({
    params: { slug: route.slug },
    props: { route },
  }));
}

const { route } = Astro.props;
const content = getRouteContent(route.slug);

const jsonLd = [
  {
    "@context": "https://schema.org",
    "@type": "TouristTrip",
    name: route.title,
    description: route.metaDescription,
    itinerary: content.days.map((d) => ({
      "@type": "ListItem",
      position: d.day,
      name: d.title,
      description: d.summary,
    })),
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    itemListElement: [
      { "@type": "ListItem", position: 1, name: "Главная", item: Astro.site?.toString() },
      { "@type": "ListItem", position: 2, name: "Маршруты", item: new URL(url("marshrut/"), Astro.site).toString() },
      { "@type": "ListItem", position: 3, name: route.title },
    ],
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    mainEntity: content.faq.map((q) => ({
      "@type": "Question",
      name: q.q,
      acceptedAnswer: { "@type": "Answer", text: q.a },
    })),
  },
];
---

<BaseLayout
  title={route.h1}
  description={route.metaDescription}
  jsonLd={jsonLd}
>
  <div class="container">
    <p class="breadcrumbs">
      <a href={url()}>Главная</a> /
      <a href={url("marshrut/")}>Маршруты</a> /
      {route.title}
    </p>

    <h1>{route.h1}</h1>

    <p class="muted" style="font-size:1.05rem">
      {content.intro}
    </p>

    <dl class="fact-list">
      <dt>Длительность</dt>
      <dd>{route.days} дней</dd>
      {route.totalKm > 0 && (
        <>
          <dt>Общий пробег</dt>
          <dd>~{route.totalKm} км</dd>
        </>
      )}
      <dt>Лучшее время</dt>
      <dd>{content.bestSeason}</dd>
      <dt>Бюджет ориентировочно</dt>
      <dd>{content.budget}</dd>
    </dl>

    <h2>План по дням</h2>
    {content.days.map((d) => (
      <div class="day-block">
        <h3>День {d.day}. {d.title}</h3>
        <p style="margin-bottom:0.5rem"><strong>Краткое:</strong> {d.summary}</p>
        <ul>
          {d.points.map((p) => <li>{p}</li>)}
        </ul>
      </div>
    ))}

    <div class="disclaimer">
      Это шаблонный план. Цены, расписание и время работы объектов уточняйте на
      официальных сайтах перед поездкой — данные актуальны на 2026 год, но могут
      измениться. Хочешь персональный план под конкретные даты и интересы — заполни
      форму ниже, AI пересоберёт маршрут.
    </div>

    <PlannerForm
      defaultDays={route.days}
      variant="inline"
    />

    <h2>Часто задаваемые вопросы</h2>
    <div>
      {content.faq.map((q) => (
        <details class="faq-item">
          <summary>{q.q}</summary>
          <p>{q.a}</p>
        </details>
      ))}
    </div>

    <h2>Похожие маршруты</h2>
    <div class="grid">
      {routes
        .filter((r) => r.slug !== route.slug)
        .slice(0, 3)
        .map((r) => (
          <a href={url(`marshrut/${r.slug}/`)} class="card" style="display:block; color: var(--color-text); text-decoration:none;">
            <div style="font-size:0.85rem; color: var(--color-text-muted); margin-bottom:0.4rem">
              {r.city} · {r.days} дней
            </div>
            <h3 style="margin: 0 0 0.4rem 0; font-family: var(--font-sans); font-size:1.1rem; color: var(--color-text);">{r.title}</h3>
            <p class="muted" style="margin-bottom:0">{r.description}</p>
          </a>
        ))}
    </div>
  </div>
</BaseLayout>
