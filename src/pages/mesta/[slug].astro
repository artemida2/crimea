---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Picture from "../../components/Picture.astro";
import PlaceCard from "../../components/PlaceCard.astro";
import places from "../../data/places.json";
import photos from "../../data/photos.json";
import { getPlaceContent } from "../../content/places-content";
import { url } from "../../utils/url";

export function getStaticPaths() {
  return places.map((place) => ({
    params: { slug: place.slug },
    props: { place },
  }));
}

const { place } = Astro.props;
const content = getPlaceContent(place.slug);

const nearby = (place.nearby ?? [])
  .map((slug) => places.find((p) => p.slug === slug))
  .filter((p): p is (typeof places)[number] => Boolean(p));

interface PhotoMeta {
  slug: string;
  author: string;
  author_url: string;
  license: string;
  license_url: string;
  page: string;
}
const photoMeta = (photos as PhotoMeta[]).find((p) => p.slug === place.image);

const ogImageUrl = place.image
  ? new URL(url(`img/${place.image}-1600.webp`).replace(/^\//, ""), Astro.site).toString()
  : undefined;

const jsonLd = [
  {
    "@context": "https://schema.org",
    "@type": "TouristAttraction",
    name: place.title,
    description: place.metaDescription,
    address: { "@type": "PostalAddress", addressRegion: "Крым", addressLocality: place.city },
    geo: place.facts.Координаты
      ? {
          "@type": "GeoCoordinates",
          latitude: parseFloat(place.facts.Координаты.split(",")[0].trim()),
          longitude: parseFloat(place.facts.Координаты.split(",")[1].trim()),
        }
      : undefined,
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    itemListElement: [
      { "@type": "ListItem", position: 1, name: "Главная", item: Astro.site?.toString() },
      { "@type": "ListItem", position: 2, name: "Места", item: new URL(url("mesta/"), Astro.site).toString() },
      { "@type": "ListItem", position: 3, name: place.title },
    ],
  },
];
---

<BaseLayout
  title={`${place.title} — Крым · издание о полуострове`}
  description={place.metaDescription}
  ogImage={ogImageUrl}
  jsonLd={jsonLd}
>
  <!-- Hero -->
  <section class="detail-hero">
    {place.image && (
      <Picture
        slug={place.image}
        alt={place.title}
        sizes="100vw"
        aspect={null}
        loading="eager"
      />
    )}
    <div class="veil" />
    <div class="hero-inner">
      <span class="eyebrow">Место · {place.city}{place.category ? ` · ${place.category}` : ""}</span>
      <h1>{place.title}</h1>
      <p class="lede">{place.shortDescription}</p>
    </div>
    {photoMeta && (
      <div class="photo-credit">
        Фото: <a href={photoMeta.author_url} target="_blank" rel="noopener">{photoMeta.author}</a> · <a href={photoMeta.license_url} target="_blank" rel="noopener">{photoMeta.license}</a>
      </div>
    )}
  </section>

  <div class="container">
    <p class="breadcrumbs">
      <a href={url()}>Главная</a><span class="sep">/</span>
      <a href={url("mesta/")}>Места</a><span class="sep">/</span>
      <span>{place.title}</span>
    </p>
  </div>

  <div class="container-content">
    <dl class="facts">
      {Object.entries(place.facts).map(([k, v]) => (
        <div>
          <dt>{k}</dt>
          <dd>{v}</dd>
        </div>
      ))}
    </dl>
  </div>

  <article class="prose">
    <h2 style="font-style: italic;">История и значение</h2>
    {content.history.map((p, i) => (
      <p class={i === 0 ? "dropcap" : ""}>{p}</p>
    ))}

    <h2 style="font-style: italic;">Как добраться</h2>
    {content.howToGet.map((p) => <p>{p}</p>)}

    <h2 style="font-style: italic;">Что посмотреть рядом</h2>
    <p>{content.nearbyDescription}</p>
  </article>

  {nearby.length > 0 && (
    <div class="container">
      <section class="section">
        <div class="card-grid">
          {nearby.map((n) => (
            <PlaceCard
              href={url(`mesta/${n.slug}/`)}
              title={n.title}
              description={n.shortDescription}
              city={n.city}
              category={n.category}
              image={n.image}
            />
          ))}
        </div>
      </section>
    </div>
  )}

  <article class="prose">
    <h2 style="font-style: italic;">Советы туристу</h2>
    <ul>
      {content.tips.map((t) => <li>{t}</li>)}
    </ul>

    <div class="disclaimer">
      Цены, расписание и условия посещения могут меняться. Перед поездкой проверяйте
      актуальные данные на официальном сайте объекта или в Яндекс.Картах.
    </div>
  </article>

  <div class="container">
    <header class="section-rule">
      <div class="num">FAQ</div>
      <div class="name">Часто задаваемые вопросы</div>
      <div class="meta">{content.faq.length}</div>
    </header>

    <div class="faq" style="padding: var(--s-5) 0 var(--s-7);">
      {content.faq.map((q) => (
        <details class="faq-item">
          <summary>{q.q}</summary>
          <p>{q.a}</p>
        </details>
      ))}
    </div>
  </div>
</BaseLayout>
