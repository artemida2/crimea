---
import BaseLayout from "../../layouts/BaseLayout.astro";
import places from "../../data/places.json";
import { getPlaceContent } from "../../content/places-content";

export function getStaticPaths() {
  return places.map((place) => ({
    params: { slug: place.slug },
    props: { place },
  }));
}

const { place } = Astro.props;
const content = getPlaceContent(place.slug);
const base = import.meta.env.BASE_URL;

const nearby = (place.nearby ?? [])
  .map((slug) => places.find((p) => p.slug === slug))
  .filter((p): p is (typeof places)[number] => Boolean(p));

const jsonLd = [
  {
    "@context": "https://schema.org",
    "@type": "TouristAttraction",
    name: place.title,
    description: place.metaDescription,
    address: { "@type": "PostalAddress", addressRegion: "Крым", addressLocality: place.city },
    geo: place.facts.Координаты
      ? {
          "@type": "GeoCoordinates",
          latitude: parseFloat(place.facts.Координаты.split(",")[0].trim()),
          longitude: parseFloat(place.facts.Координаты.split(",")[1].trim()),
        }
      : undefined,
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    itemListElement: [
      { "@type": "ListItem", position: 1, name: "Главная", item: Astro.site?.toString() },
      { "@type": "ListItem", position: 2, name: "Места", item: `${Astro.site}${base.slice(1)}/mesta/` },
      { "@type": "ListItem", position: 3, name: place.title },
    ],
  },
];
---

<BaseLayout
  title={`${place.title} в Крыму — история, как добраться, цены 2026`}
  description={place.metaDescription}
  jsonLd={jsonLd}
>
  <div class="container">
    <p class="breadcrumbs">
      <a href={base + "/"}>Главная</a> /
      <a href={`${base}/mesta/`}>Места</a> /
      {place.title}
    </p>

    <h1>{place.title}</h1>
    <p class="muted" style="font-size:1.05rem">{place.shortDescription}</p>

    <dl class="fact-list">
      {Object.entries(place.facts).map(([k, v]) => (
        <>
          <dt>{k}</dt>
          <dd>{v}</dd>
        </>
      ))}
    </dl>

    <h2>История и значение</h2>
    {content.history.map((p) => <p>{p}</p>)}

    <h2>Как добраться</h2>
    {content.howToGet.map((p) => <p>{p}</p>)}

    <h2>Что посмотреть рядом</h2>
    <p>{content.nearbyDescription}</p>

    {nearby.length > 0 && (
      <div class="grid">
        {nearby.map((n) => (
          <a href={`${base}/mesta/${n.slug}/`} class="card" style="display:block; color: var(--color-text); text-decoration:none;">
            <div style="font-size:0.85rem; color: var(--color-text-muted); margin-bottom:0.4rem">
              {n.city}
            </div>
            <h3 style="margin: 0 0 0.4rem 0; font-family: var(--font-sans); font-size:1.05rem; color: var(--color-text);">{n.title}</h3>
            <p class="muted" style="margin-bottom:0">{n.shortDescription}</p>
          </a>
        ))}
      </div>
    )}

    <h2>Советы туристу</h2>
    <ul>
      {content.tips.map((t) => <li>{t}</li>)}
    </ul>

    <div class="disclaimer">
      Цены, расписание и условия посещения могут меняться. Перед поездкой проверяйте
      актуальные данные на официальном сайте объекта или в Яндекс.Картах.
    </div>

    <h2>Часто задаваемые вопросы</h2>
    <div>
      {content.faq.map((q) => (
        <details class="faq-item">
          <summary>{q.q}</summary>
          <p>{q.a}</p>
        </details>
      ))}
    </div>
  </div>
</BaseLayout>
