---
import BaseLayout from "../layouts/BaseLayout.astro";
import Picture from "../components/Picture.astro";
import PlannerForm from "../components/PlannerForm.astro";
import RouteCard from "../components/RouteCard.astro";
import PlaceCard from "../components/PlaceCard.astro";
import routes from "../data/routes.json";
import places from "../data/places.json";
import { url } from "../utils/url";

const description =
  "Издание о Крыме: маршруты, места, истории — и AI, который собирает ваш план поездки. 3, 7, 10, 14 дней под ваши даты, бюджет и интересы.";

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  name: "Крым · издание о полуострове",
  url: Astro.site?.toString(),
  potentialAction: {
    "@type": "SearchAction",
    target: `${url()}?q={search_term_string}`,
    "query-input": "required name=search_term_string",
  },
};
---

<BaseLayout
  title="Крым · маршруты, места, AI-планировщик"
  description={description}
  jsonLd={jsonLd}
>
  <!-- ============ HERO ============ -->
  <section class="hero-editorial">
    <Picture
      slug="hero-coast"
      alt="Ялта с канатной дороги, Южный берег Крыма"
      sizes="100vw"
      aspect={null}
      loading="eager"
    />
    <div class="veil" />
    <div class="hero-inner">
      <span class="eyebrow">Издание №01 · Сезон 2026</span>
      <h1>Крым,<br />собранный<br />заново.</h1>
      <p class="lede">
        Маршруты, которые работают. Места, которые помнят. И AI-редакция, которая
        соберёт ваш план поездки за 10 секунд — под даты, состав и бюджет.
      </p>
      <div>
        <a href="#planner" class="btn btn-cream">Собрать маршрут</a>
      </div>
    </div>
    <div class="photo-credit">
      Фото: <a href="https://commons.wikimedia.org/wiki/User:A.Savin" target="_blank" rel="noopener">A.Savin</a> · CC BY-SA 3.0
    </div>
  </section>

  <!-- ============ ROUTES ============ -->
  <div class="container">
    <header class="section-rule">
      <div class="num">01</div>
      <div class="name">Маршруты</div>
      <div class="meta">{routes.length} готовых · 12 городов</div>
    </header>

    <section class="section">
      <div class="card-grid">
        {routes.map((r) => (
          <RouteCard
            href={url(`marshrut/${r.slug}/`)}
            title={r.title}
            description={r.description}
            days={r.days}
            city={r.city}
            tags={r.tags}
            image={r.image}
          />
        ))}
      </div>
      <p class="text-center" style="margin-top: var(--s-7)">
        <a href={url("marshrut/")} class="btn btn-outline">Все маршруты</a>
      </p>
    </section>
  </div>

  <!-- ============ PLACES ============ -->
  <div class="container">
    <header class="section-rule">
      <div class="num">02</div>
      <div class="name">Места</div>
      <div class="meta">{places.length} достопримечательностей</div>
    </header>

    <section class="section">
      <div class="card-grid">
        {places.map((p) => (
          <PlaceCard
            href={url(`mesta/${p.slug}/`)}
            title={p.title}
            description={p.shortDescription}
            city={p.city}
            category={p.category}
            image={p.image}
          />
        ))}
      </div>
      <p class="text-center" style="margin-top: var(--s-7)">
        <a href={url("mesta/")} class="btn btn-outline">Все места</a>
      </p>
    </section>
  </div>

  <!-- ============ PULL QUOTE ============ -->
  <div class="container">
    <p class="pull">
      «Крым — это не одно путешествие, а двенадцать, наложенных друг на друга».
    </p>
  </div>

  <!-- ============ PLANNER FORM ============ -->
  <div class="container">
    <header class="section-rule" id="planner">
      <div class="num">03</div>
      <div class="name">AI-планировщик</div>
      <div class="meta">~10 секунд</div>
    </header>
  </div>

  <section class="form-section">
    <PlannerForm />
  </section>

  <!-- ============ HOW IT WORKS ============ -->
  <div class="container">
    <header class="section-rule">
      <div class="num">04</div>
      <div class="name">Как это работает</div>
      <div class="meta">три шага</div>
    </header>

    <section class="section">
      <div class="card-grid-2" style="grid-template-columns: repeat(3, 1fr);">
        <div>
          <div class="serif-italic" style="font-size: 3.4rem; color: var(--c-burgundy); line-height:1; margin-bottom: var(--s-4);">i.</div>
          <h3 style="font-style: italic;">Выбираете формат</h3>
          <p class="muted">
            Готовый маршрут из редакции — или формируете свой через AI: даты, бюджет,
            состав, главный интерес.
          </p>
        </div>
        <div>
          <div class="serif-italic" style="font-size: 3.4rem; color: var(--c-burgundy); line-height:1; margin-bottom: var(--s-4);">ii.</div>
          <h3 style="font-style: italic;">AI собирает план</h3>
          <p class="muted">
            ~10 секунд — и у вас план по дням с тайм-слотами, адресами и координатами.
            Места проверены вручную и через 2GIS.
          </p>
        </div>
        <div>
          <div class="serif-italic" style="font-size: 3.4rem; color: var(--c-burgundy); line-height:1; margin-bottom: var(--s-4);">iii.</div>
          <h3 style="font-style: italic;">Получаете PDF</h3>
          <p class="muted">
            На email приходит файл с маршрутом и ссылкой на Яндекс.Карты — открывается
            на телефоне в один клик.
          </p>
        </div>
      </div>
    </section>
  </div>
</BaseLayout>

<style>
  /* Restack the 3-step on tablet/mobile */
  @media (max-width: 800px) {
    .card-grid-2[style*="3, 1fr"] { grid-template-columns: 1fr 1fr !important; gap: var(--s-6) !important; }
  }
  @media (max-width: 540px) {
    .card-grid-2[style*="3, 1fr"] { grid-template-columns: 1fr !important; }
  }
</style>
