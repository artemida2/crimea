---
import BaseLayout from "../layouts/BaseLayout.astro";
import PlannerForm from "../components/PlannerForm.astro";
import RouteCard from "../components/RouteCard.astro";
import PlaceCard from "../components/PlaceCard.astro";
import routes from "../data/routes.json";
import places from "../data/places.json";

const base = import.meta.env.BASE_URL;
const description =
  "AI-планировщик отпуска в Крыму и подробный гид по достопримечательностям. Готовые маршруты на 3, 7, 10, 14 дней с адаптацией под ваши даты, бюджет и интересы.";

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  name: "Крым: маршруты и AI-гид",
  url: Astro.site?.toString(),
  potentialAction: {
    "@type": "SearchAction",
    target: `${base}/?q={search_term_string}`,
    "query-input": "required name=search_term_string",
  },
};
---

<BaseLayout
  title="AI-планировщик отпуска в Крыму и гид по достопримечательностям"
  description={description}
  jsonLd={jsonLd}
>
  <section class="hero">
    <div class="container">
      <h1>Крым: маршруты и AI-гид</h1>
      <p>
        Готовые маршруты по Крыму на 3, 7, 10 и 14 дней. AI пересоберёт план под ваши даты,
        бюджет, состав и интересы — и пришлёт PDF на email.
      </p>
      <a href="#planner" class="btn btn-accent">Собрать свой маршрут</a>
    </div>
  </section>

  <div class="container">
    <section class="section">
      <h2 class="section-title">Готовые маршруты</h2>
      <div class="grid">
        {routes.map((r) => (
          <RouteCard
            href={`${base}/marshrut/${r.slug}/`}
            title={r.title}
            description={r.description}
            days={r.days}
            city={r.city}
            tags={r.tags}
          />
        ))}
      </div>
      <p style="text-align:center; margin-top:1.5rem">
        <a href={`${base}/marshrut/`}>Все маршруты →</a>
      </p>
    </section>

    <section class="section">
      <h2 class="section-title">Главные достопримечательности</h2>
      <div class="grid">
        {places.map((p) => (
          <PlaceCard
            href={`${base}/mesta/${p.slug}/`}
            title={p.title}
            description={p.shortDescription}
            city={p.city}
            category={p.category}
          />
        ))}
      </div>
      <p style="text-align:center; margin-top:1.5rem">
        <a href={`${base}/mesta/`}>Все места →</a>
      </p>
    </section>

    <section class="section">
      <PlannerForm variant="hero" />
    </section>

    <section class="section">
      <h2 class="section-title">Как это работает</h2>
      <div class="grid">
        <div class="card">
          <h3>1. Выбираете формат</h3>
          <p class="muted">
            Готовый маршрут или формируете свой через AI: даты, бюджет, состав, интересы.
          </p>
        </div>
        <div class="card">
          <h3>2. AI собирает план</h3>
          <p class="muted">
            За ~10 секунд получаете план по дням с тайм-слотами и адресами. Все места
            проверены, координаты валидны.
          </p>
        </div>
        <div class="card">
          <h3>3. Получаете PDF</h3>
          <p class="muted">
            На email приходит файл с маршрутом и ссылкой на Яндекс.Карты — открывается
            на телефоне в один клик.
          </p>
        </div>
      </div>
    </section>
  </div>
</BaseLayout>
